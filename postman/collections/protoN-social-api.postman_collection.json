{
  "info": {
    "_postman_id": "2f135dfd-c65e-4cbc-a07b-58b197919c78",
    "name": "protoN for Social API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "End-to-end API checks for protoN for Social."
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.environment.get('testUsername')) {",
          "  const suffix = Date.now().toString();",
          "  pm.environment.set('testUsername', `proton_${suffix}`);",
          "  pm.environment.set('testEmail', `proton_${suffix}@example.com`);",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{testUsername}}\",\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('register succeeds', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "var responseJson = pm.response.json();",
                  "pm.expect(responseJson.token).to.be.a('string');",
                  "pm.environment.set('authToken', responseJson.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"{{testUsername}}\",\n  \"password\": \"{{testPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('login succeeds', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "var responseJson = pm.response.json();",
                  "pm.expect(responseJson.user.username).to.eql(pm.environment.get('testUsername'));",
                  "pm.environment.set('authToken', responseJson.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "me"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('profile fetch succeeds', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "var responseJson = pm.response.json();",
                  "pm.expect(responseJson.username).to.eql(pm.environment.get('testUsername'));"
                ]
              }
            }
          ]
        }
      ]
    },
